PUID=1000
PGID=1000
APP_AUTH_ENABLED=true
APP_USERNAME=admin
# REQUIRED: change this or BookGrab will refuse to start.
APP_PASSWORD=change-me
# REQUIRED: set a random 32+ character value or BookGrab will refuse to start.
# Example: openssl rand -hex 32
APP_SESSION_SECRET=change-this-random-secret
DATABASE_PATH=/config/app.db
CONFIG_DIR=/config

MAM_BASE_URL=https://www.myanonamouse.net
MAM_COOKIE=
MAM_UID=
MAM_SESSION=
MAM_TIMEOUT_SECONDS=30
MAM_HASH_LOOKUP_ENABLED=false
MAM_HASH_LOOKUP_MAX_PER_RUN=100
MAM_HASH_LOOKUP_CACHE_TTL_DAYS=30
MAM_HASH_LOOKUP_RETRY_ERROR_TTL_HOURS=24
MAM_HASH_LOOKUP_NO_MATCH_TTL_DAYS=30
MAM_HASH_LOOKUP_SCOPE=mam_only
MAM_TRACKER_HOSTS=t.myanonamouse.net,myanonamouse.net,www.myanonamouse.net
# Optional: set explicit qBittorrent categories for category scope. When unset, defaults to QBIT_CATEGORY_AUDIOBOOKS and QBIT_CATEGORY_EBOOKS.
# MAM_HASH_LOOKUP_INCLUDE_CATEGORIES=audiobooks,ebooks
# Optional scheduled qBittorrent/MAM hash sync. Requires MAM_HASH_LOOKUP_ENABLED=true.
# Scheduled runs skip if any sync is already running; missed runs are not queued.
# Use standard 5-field cron syntax and an IANA timezone such as America/Los_Angeles.
# Long initial syncs may need multiple scheduled runs when MAM_HASH_LOOKUP_MAX_PER_RUN is set.
MAM_HASH_LOOKUP_CRON_ENABLED=false
MAM_HASH_LOOKUP_CRON=0 3 * * *
MAM_HASH_LOOKUP_CRON_TIMEZONE=UTC

QBIT_BASE_URL=http://qbittorrent:8080
QBIT_USERNAME=admin
QBIT_PASSWORD=
QBIT_CATEGORY_AUDIOBOOKS=audiobooks
QBIT_CATEGORY_EBOOKS=ebooks
QBIT_SAVE_PATH_AUDIOBOOKS=
QBIT_SAVE_PATH_EBOOKS=

DEFAULT_MEDIA_TYPE=audiobook
DEFAULT_SORT=seedersDesc
DEFAULT_SEARCH_TYPE=active
SEARCH_CACHE_TTL_SECONDS=1800
SEARCH_CACHE_MAX_ENTRIES=200

PLEX_ENABLED=false
PLEX_BASE_URL=http://plex:32400
PLEX_TOKEN=
PLEX_LIBRARY_SECTION_ID=
PLEX_LIBRARY_NAME=Audiobooks

AUDIOBOOKSHELF_ENABLED=false
AUDIOBOOKSHELF_BASE_URL=http://audiobookshelf:80
AUDIOBOOKSHELF_TOKEN=
AUDIOBOOKSHELF_LIBRARY_ID=

LIBRARY_PRESENCE_CACHE_TTL_SECONDS=600
LIBRARY_PRESENCE_REQUIRE_NARRATOR=true

# Optional host/IP helper variable for your own substitutions.
# If you reference ${IP} in other values, define it here to avoid Compose warnings.
IP=

IMPORT_ENABLED=false
IMPORT_INTERVAL_SECONDS=300
IMPORT_MODE=hardlink
IMPORT_CONFLICT_POLICY=skip
IMPORT_AUDIOBOOK_LIBRARY_PATH=
IMPORT_EBOOK_LIBRARY_PATH=
IMPORT_AUDIOBOOK_EXTENSIONS=.m4b,.mp3,.m4a,.flac,.ogg,.opus,.aac
IMPORT_EBOOK_EXTENSIONS=.epub,.pdf,.mobi,.azw3,.cbz,.cbr
IMPORT_REQUIRE_SEEDING_OR_COMPLETE=true
IMPORT_DRY_RUN=false
# Restrict importer source paths. Must match the paths BookGrab can see.
IMPORT_ALLOWED_DOWNLOAD_ROOTS=/downloads
